{
    "manifest_version": 3,
    "name": "Roshan",
    "version": "0.1.0",
    "description": "Flags propaganda-style rhetoric in articles",
    "permissions": ["activeTab", "scripting", "contextMenus"],
    "host_permissions": ["<all_urls>"],
    "background": {
      "service_worker": "background.js"
    },
    "action": {
      "default_popup": "popup.html"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js"],
        "run_at": "document_idle"
      }
    ]
  }